# ─────────────────────────────────────────────────────────────
# Sabores de Mamá · Backend · Variables de entorno (ejemplo)
# Copia este archivo a `.env` y completa los valores reales.
# ─────────────────────────────────────────────────────────────

# Servidor
PORT=4000
NODE_ENV=development
# Límite de POST/GET a /api/pedidos por IP por minuto (default 10).
# Súbelo para correr la suite E2E desde una sola IP sin toparte con 429.
PEDIDOS_RATE_LIMIT=10

# Base de datos PostgreSQL
# En Railway: usa la DATABASE_URL que provee el plugin de Postgres.
DATABASE_URL=postgresql://usuario:password@localhost:5432/sabores_de_mama
# Forzar SSL (Railway/Neon/Supabase normalmente lo requieren). true | false
PGSSL=false
# Ejecutar migraciones automáticamente al arrancar (idempotentes)
RUN_MIGRATIONS=true

# Autenticación (JWT)
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=8h

# Admin inicial (se crea/seedea en las migraciones si no existe)
ADMIN_EMAIL=admin@saboresdemama.com
ADMIN_PASSWORD=cambia_esta_password
ADMIN_NOMBRE=Administradora

# CORS · orígenes permitidos separados por coma. Usa * para permitir todos.
CORS_ORIGIN=http://localhost:5173,http://localhost:4173

# URL pública del sitio (para enlaces en los correos)
CLIENT_URL=https://saboresdemama.com

# ── Correo (Nodemailer / SMTP) ──
# Si no configuras SMTP, el envío de correos se omite y sólo se registra en logs.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tucorreo@gmail.com
SMTP_PASS=app_password_de_gmail
# Remitente de los correos transaccionales
SMTP_FROM="Sabores de Mamá <pedidos@saboresdemama.com>"
# (alias heredado, opcional; SMTP_FROM tiene prioridad)
MAIL_FROM="Sabores de Mamá <pedidos@saboresdemama.com>"

# ── Datos bancarios (incluidos en el correo de "solicitud_recibida") ──
# Se aceptan dos esquemas de nombres (usa uno). Esquema del checklist de deploy:
BANCO_NOMBRE=Estela Zavalla
BANCO_CUENTA=0000000000
BANCO_TIPO=Cuenta Corriente
BANCO_RUT=11.111.111-1
BANCO_EMAIL=pagos@saboresdemama.com
BANCO_BANCO=Banco de Chile
# Esquema alternativo (equivalente; BANCO_* tiene prioridad si ambos existen):
# BANK_TITULAR / BANK_NUMERO / BANK_TIPO_CUENTA / BANK_RUT / BANK_EMAIL / BANK_BANCO
