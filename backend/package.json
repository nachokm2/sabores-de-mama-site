{
  "name": "sabores-de-mama-backend",
  "version": "1.0.0",
  "description": "API backend de Sabores de Mamá (Express + PostgreSQL)",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
